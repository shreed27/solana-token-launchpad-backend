generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  createdAt DateTime   @default(now())
  launches  Launch[]
  purchases Purchase[]
}

model Launch {
  id            String      @id @default(cuid())
  creatorId     String
  name          String
  symbol        String
  totalSupply   Float
  pricePerToken Float
  startsAt      DateTime
  endsAt        DateTime
  maxPerWallet  Float
  description   String?
  createdAt     DateTime    @default(now())
  creator       User        @relation(fields: [creatorId], references: [id])
  tiers         Tier[]
  vesting       Vesting?
  whitelist     Whitelist[]
  purchases     Purchase[]
  referrals     Referral[]

  @@index([creatorId])
}

model Tier {
  id            String  @id @default(cuid())
  launchId      String
  minAmount     Float
  maxAmount     Float
  pricePerToken Float
  launch        Launch  @relation(fields: [launchId], references: [id])
}

model Vesting {
  id          String  @id @default(cuid())
  launchId    String  @unique
  cliffDays   Int
  vestingDays Int
  tgePercent  Float
  launch      Launch  @relation(fields: [launchId], references: [id])
}

model Whitelist {
  id       String @id @default(cuid())
  launchId String
  address  String
  launch   Launch @relation(fields: [launchId], references: [id])

  @@unique([launchId, address])
  @@index([launchId])
}

model Referral {
  id              String     @id @default(cuid())
  launchId        String
  code            String
  discountPercent Float
  maxUses         Int
  usedCount       Int        @default(0)
  launch          Launch     @relation(fields: [launchId], references: [id])
  purchases       Purchase[]

  @@unique([launchId, code])
}

model Purchase {
  id            String    @id @default(cuid())
  launchId      String
  userId        String
  walletAddress String
  amount        Float
  totalCost     Float
  txSignature   String    @unique
  referralId    String?
  createdAt     DateTime  @default(now())
  launch        Launch    @relation(fields: [launchId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  referral      Referral? @relation(fields: [referralId], references: [id])

  @@index([launchId])
  @@index([userId])
}
